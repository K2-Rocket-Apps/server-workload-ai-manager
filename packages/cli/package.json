{
  "name": "@mistral/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "mistral": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
