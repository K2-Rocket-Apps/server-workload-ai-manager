    "lint": "echo ok"
  },
  "dependencies": {
    "@mistral/alerts": "workspace:*",
    "@mistral/core": "workspace:*",
    "@mistral/daemon": "workspace:*",
    "@mistral/mcp": "workspace:*",
    "@mistral/pve": "workspace:*",
    "@mistral/web": "workspace:*",
    "commander": "^14.0.0",
    "figures": "^6.1.0",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.0",
    "string-width": "^7.2.0",
    "wrap-ansi": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
